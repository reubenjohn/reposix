#!/usr/bin/env bash
#
# Credential-hygiene pre-push hook (OP-7 from HANDOFF.md).
#
# Rejects a push if any committed file on the outgoing range contains
# a literal Atlassian API token (prefix `ATATT3`) or GitHub PAT (prefix
# `ghp_` or `github_pat_`). These are cheap one-shot grep checks that
# would have caught a credential leak before it ever hit the origin.
#
# To install:
#   bash scripts/install-hooks.sh
#
# To bypass intentionally (strongly discouraged — rotate the token first):
#   git push --no-verify
#
# Environment:
#   REPOSIX_HOOKS_QUIET=1   suppress informational output; still rejects on hit.

set -euo pipefail

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

quiet="${REPOSIX_HOOKS_QUIET:-0}"

log() {
  if [[ "$quiet" != "1" ]]; then
    printf '%b\n' "$*" >&2
  fi
}

# Patterns require the credential prefix PLUS 20+ chars of token-
# alphabet entropy. This distinguishes REAL tokens (Atlassian = ~192
# chars, GitHub PATs ~40 chars) from format documentation like
# "tokens start with ATATT3…" or a prose reference "ATATT3xF" —
# neither has 20 entropy chars after the prefix, so neither trips
# the scanner. Defense vs whitelist: a real token accidentally pasted
# into any tracked file (including .md docs) still gets caught.
readonly PATTERNS=(
  'ATATT3[A-Za-z0-9_+/=-]{20,}'                     # Atlassian API token.
  'Bearer[[:space:]]+ATATT3[A-Za-z0-9_+/=-]{20,}'   # Atlassian in Bearer header.
  'ghp_[A-Za-z0-9]{20,}'                            # GitHub classic PAT.
  'github_pat_[A-Za-z0-9_]{20,}'                    # GitHub fine-grained PAT.
)

# Minimal excludes. Format-documentation strings in docs/CHANGELOG etc.
# no longer need a whitelist because the stricter patterns above only
# match real-entropy tokens.
readonly EXCLUDE_DIRS=(
  '.git'
  'target'
  'node_modules'
  # The hook files themselves contain the pattern literals by design.
  'scripts/hooks'
)

# Resolve the list of commits being pushed.  stdin receives lines of
# "<local ref> <local sha> <remote ref> <remote sha>".  If the remote
# sha is 40 zeros the branch is new and we scan against the merge-base
# with the default branch instead.
scan_refs=()
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ -z "${local_sha:-}" ]]; then
    continue
  fi
  if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
    continue  # Deletion push.
  fi
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    # New branch — diff against the first reachable ancestor commit.
    base=$(git rev-list --max-parents=0 "$local_sha" 2>/dev/null | head -1)
    if [[ -n "$base" ]]; then
      scan_refs+=("${base}..${local_sha}")
    else
      scan_refs+=("$local_sha")
    fi
  else
    scan_refs+=("${remote_sha}..${local_sha}")
  fi
done

# Fallback if stdin was empty (e.g., `git push` with nothing new — Git
# still invokes the hook).  Exit clean; no work to do.
if [[ ${#scan_refs[@]} -eq 0 ]]; then
  exit 0
fi

log "${YELLOW}→${NC} reposix credential-hygiene pre-push hook scanning ${#scan_refs[@]} ref range(s)..."

hit=0
for range in "${scan_refs[@]}"; do
  # List all files changed in this range.
  files=$(git diff --name-only "$range" 2>/dev/null || true)
  for file in $files; do
    # Skip excluded dirs.
    skip=0
    for excl in "${EXCLUDE_DIRS[@]}"; do
      if [[ "$file" == "$excl"* ]]; then
        skip=1
        break
      fi
    done
    [[ "$skip" -eq 1 ]] && continue

    # Skip files that don't exist at the tip of the range (deletions).
    tip_sha="${range##*..}"
    if ! git cat-file -e "${tip_sha}:${file}" 2>/dev/null; then
      continue
    fi

    # Scan the tip-of-range content for each pattern.
    content=$(git show "${tip_sha}:${file}" 2>/dev/null || true)
    for pattern in "${PATTERNS[@]}"; do
      if printf '%s' "$content" | grep -qE "$pattern"; then
        printf '%b\n' "${RED}✖ credential-prefix match in ${file}:${NC} pattern ${pattern}" >&2
        hit=$((hit + 1))
      fi
    done
  done
done

if [[ "$hit" -gt 0 ]]; then
  printf '%b\n' "${RED}✖ pre-push rejected:${NC} ${hit} credential-prefix hit(s) above." >&2
  printf '%b\n' "${YELLOW}→${NC} If this is a false positive (sample token in a test fixture), move it to" >&2
  printf '%b\n' '  a variable-substituted form (e.g., "$TOKEN" instead of a literal prefix) and re-push.' >&2
  printf '%b\n' "${YELLOW}→${NC} If this is a real token, ROTATE IT NOW at https://id.atlassian.com/" >&2
  printf '%b\n' "  manage-profile/security/api-tokens or https://github.com/settings/tokens before" >&2
  printf '%b\n' "  attempting anything else." >&2
  exit 1
fi

log "${GREEN}✓${NC} no credential prefixes detected."

# --- Catalog coverage (non-fatal until §7-H) ------------------------------
# Warns if any TODO row in the v0.11.1 living catalog lacks a plan. Flips
# to fatal at §7-H per HANDOVER.md.
if [ -f scripts/catalog.py ] && [ -f .planning/v0.11.1-catalog.json ]; then
  if ! python3 scripts/catalog.py coverage >/dev/null 2>&1; then
    printf '%b\n' "${YELLOW}!${NC} catalog has unplanned TODO rows (non-fatal until §7-H)" >&2
  else
    log "${GREEN}✓${NC} catalog coverage clean."
  fi
fi

# --- SESSION-END-STATE verdict (non-fatal warning) ------------------------
# Per HANDOVER.md §0.8 / CLAUDE.md "Freshness invariants". Surfaces
# verifier-graded session done-ness as a warning — pre-push does not block
# on RED because the contract is session-scoped and includes long-running
# items (e.g. mermaid playwright walks) that don't belong on every commit.
if [ -f scripts/end-state.py ] && [ -f .planning/SESSION-END-STATE.json ]; then
  if ! python3 scripts/end-state.py verdict >/dev/null 2>&1; then
    printf '%b\n' "${YELLOW}!${NC} SESSION-END-STATE verdict is RED (non-fatal warning)" >&2
    printf '%b\n' "${YELLOW}→${NC} run \`python3 scripts/end-state.py verify\` to refresh, then \`verdict\` to re-grade" >&2
  else
    log "${GREEN}✓${NC} SESSION-END-STATE verdict GREEN."
  fi
fi

# --- Docs-site validation -------------------------------------------------
# Only run mkdocs --strict when docs/ or mkdocs.yml are touched in any of
# the outgoing ref ranges. mkdocs runs in <2s so this stays cheap.
docs_touched=0
for range in "${scan_refs[@]}"; do
  if git diff --name-only "$range" 2>/dev/null | grep -qE '^(docs/|mkdocs\.yml$)'; then
    docs_touched=1
    break
  fi
done
if [[ "$docs_touched" -eq 1 ]]; then
  log "${YELLOW}→${NC} docs touched; running scripts/check-docs-site.sh..."
  if ! bash scripts/check-docs-site.sh 2>&1; then
    printf '%b\n' "${RED}✖ pre-push rejected:${NC} scripts/check-docs-site.sh failed." >&2
    printf '%b\n' "${YELLOW}→${NC} Fix mkdocs --strict errors or any 'Syntax error in text' renders before re-pushing." >&2
    exit 1
  fi
  log "${GREEN}✓${NC} docs-site clean."

  # Per HANDOVER §0.1: assert every source-mermaid page has a current
  # playwright artifact proving the SVG renders. Source→artifact check
  # only — the actual browser walk is a session-time activity (see
  # scripts/check-mermaid-renders.sh header). FATAL because a stale or
  # missing artifact means the §0.1.b regression could be back undetected.
  log "${YELLOW}→${NC} running scripts/check-mermaid-renders.sh..."
  if ! bash scripts/check-mermaid-renders.sh 2>&1; then
    printf '%b\n' "${RED}✖ pre-push rejected:${NC} scripts/check-mermaid-renders.sh failed." >&2
    printf '%b\n' "${YELLOW}→${NC} Re-run the playwright walk per CLAUDE.md \"Docs-site validation\" rules:" >&2
    printf '%b\n' "  mkdocs serve, navigate cold to each page that source-references \`\`\`mermaid," >&2
    printf '%b\n' "  assert pre.mermaid svg > 0, write artifact JSON to .planning/verifications/playwright/." >&2
    exit 1
  fi
  log "${GREEN}✓${NC} mermaid renders verified via artifact JSON."
fi

# --- Rust quality gates ---------------------------------------------------
# Run fmt + clippy before anything reaches CI. Fast checks only; FUSE
# integration tests require fusermount3 and are gated behind --features.
log "${YELLOW}→${NC} running cargo fmt check..."
if ! cargo fmt --all -- --check 2>&1; then
  printf '%b\n' "${RED}✖ pre-push rejected:${NC} cargo fmt --all -- --check failed." >&2
  printf '%b\n' "${YELLOW}→${NC} Run: cargo fmt --all" >&2
  exit 1
fi
log "${GREEN}✓${NC} fmt clean."

log "${YELLOW}→${NC} running cargo clippy..."
if ! cargo clippy --workspace --all-targets -- -D warnings 2>&1; then
  printf '%b\n' "${RED}✖ pre-push rejected:${NC} cargo clippy reported errors." >&2
  exit 1
fi
log "${GREEN}✓${NC} clippy clean."

exit 0
