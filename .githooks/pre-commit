#!/usr/bin/env bash
# .githooks/pre-commit -- project-base + optional personal add-on chain.
#
# Composition rule:
#   1. cargo fmt --check on staged .rs files (fast-feedback on fmt drift).
#   2. Quality Gates runner --cadence pre-commit (catalog rows tagged
#      pre-commit, e.g. file-size-limits).
#   3. Personal global hook at ~/.git-hooks/pre-commit chains in at the
#      END if executable and non-delegate.
#
# When new project-side logic is added later, slot it between (1) and
# (2) only if it must run BEFORE the runner; otherwise add a catalog
# row tagged pre-commit and let (2) pick it up. The recursion guard
# mirrors .githooks/pre-push: skip globals whose body contains the
# "delegate to repo-local" sentinel.
#
# Bypass (discouraged): git commit --no-verify

set -uo pipefail

readonly REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# (0) Fixture-identity backstop — git-native defense-in-depth for leaf-isolation guard A
# (.claude/hooks/leaf-isolation-guard.sh). Rejects a commit whose author OR committer
# identity carries the throwaway fixture token `t <t@t>` in the SHARED repo. This runs
# FIRST (before fmt + the runner) so the security reject is independent of the toolchain,
# and it fires ONLY where core.hooksPath points at this .githooks dir — i.e. the shared
# repo. A /tmp fixture clone does NOT inherit this hook, so fixture commits stay ALLOWED
# there (where they belong). Coverage note: this backstop catches fixture COMMITS on the
# non-Bash-tool bypass path the PreToolUse hook cannot see; it does NOT catch `reposix
# init` / `git config` writes (those need the PreToolUse hook or the filed binary-side
# backstop). Founding incident: S-260707-pr-08 (`t <t@t>` flipped core.bare=true).
# `git var GIT_{AUTHOR,COMMITTER}_IDENT` renders the email inside angle brackets, so
# matching `<t@t>` is exact and cannot false-positive on a real address that merely
# contains the substring (e.g. `<scott@things.io>`).
fixture_ident_backstop() {
  local author committer
  author="$(git var GIT_AUTHOR_IDENT 2>/dev/null || true)"
  committer="$(git var GIT_COMMITTER_IDENT 2>/dev/null || true)"
  for tok in '<t@t>'; do
    if printf '%s\n%s\n' "$author" "$committer" | grep -qF "$tok"; then
      echo "pre-commit: BLOCKED — commit identity carries the throwaway fixture token '$tok'." >&2
      echo "  author=[$author] committer=[$committer]" >&2
      echo "WHY: the fixture identity 't <t@t>' must NEVER reach shared history or origin —" >&2
      echo "     S-260707-pr-08: a fixture-identity leaf corrupted the shared repo for every" >&2
      echo "     concurrent agent. RECOVERY: commit real work under a real git identity; run" >&2
      echo "     fixture/test commits inside a /tmp clone (which does not inherit this hook)." >&2
      exit 1
    fi
  done
}
fixture_ident_backstop

# (1) cargo fmt --check on staged .rs files.
#
# Catches fmt drift at commit time so it doesn't accumulate across long
# unpushed local stacks (the autonomous-run pattern lands many commits
# between pushes; if fmt only runs at pre-push, drift compounds and
# surfaces against a 100+-commit range -- already happened with P73/P75,
# fixed in 61ee88b).
#
# Scope: fmt only. Clippy + tests stay at pre-push (too slow for
# every commit). Bypass: git commit --no-verify (discouraged).
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.rs$'; then
  if ! cargo fmt --all -- --check >/dev/null 2>&1; then
    echo "pre-commit: cargo fmt --check failed. Run 'cargo fmt --all' and re-stage." >&2
    exit 1
  fi
fi

# (2) Quality Gates runner -- propagates exit code.
# Avoid `if ! cmd; then exit $?; fi` -- $? after `! cmd` is the exit of
# the negation (always 0), masking the real failure. Same pattern as
# .githooks/pre-push step (2).
SECONDS=0
python3 "$REPO_ROOT/quality/runners/run.py" --cadence pre-commit
RUNNER_EXIT=$?
if [[ $RUNNER_EXIT -ne 0 ]]; then
  exit "$RUNNER_EXIT"
fi

# (2b) Non-blocking timing-budget tripwire. quality/CLAUDE.md § Cadences documents
# pre-commit <2s as a FIXED whole-repo cost (does NOT scale with diff size). A creep
# past budget usually means a new whole-repo gate, not a bigger diff. Warn only; never
# touch the exit code (a real FAIL already exited above). Same class of hook-internal
# comment as the blocks above -- not a doc-alignment claim, no catalog row.
elapsed=$SECONDS
if [[ $elapsed -gt 3 ]]; then
  echo "pre-commit: WARN — took ${elapsed}s (budget ~2s, quality/CLAUDE.md § Cadences) — check for a new whole-repo gate before assuming diff size is the cause." >&2
fi

# (3) Optional personal add-on chain.
GLOBAL="$HOME/.git-hooks/pre-commit"
if [[ -x "$GLOBAL" ]] && ! grep -q "delegate to repo-local" "$GLOBAL" 2>/dev/null; then
  exec "$GLOBAL" "$@"
fi

exit 0
