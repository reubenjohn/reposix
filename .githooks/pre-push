#!/usr/bin/env bash
# .githooks/pre-push -- Quality Gates pre-push hook (tracked under .githooks/).
#
# Body composition:
#   (1) Credential-hygiene gate (P0, fail-fast). Stdin (push-ref ranges
#       from git) is piped to quality/gates/structure/cred-hygiene.sh,
#       which scans the outgoing range for token prefixes (verbatim
#       PATTERNS + EXCLUDE_DIRS migrated from this hook in P60 Wave D).
#   (2) Quality Gates runner. python3 quality/runners/run.py --cadence
#       pre-push composes every catalog row tagged pre-push: cargo fmt
#       + clippy + mkdocs --strict + mermaid renders + doc links +
#       badges-resolve + freshness invariants + banned words.
#   (3) Optional personal add-on chain. If ~/.git-hooks/pre-push exists,
#       invoke it with the same stdin so personal global checks (e.g.
#       a secret scan) run AFTER the project's base layer. Recursion
#       guard: only delegate when `git config core.hooksPath` is SET --
#       which proves git invoked US directly (the project hook is the
#       entry point), so the global hook hasn't already run. When
#       core.hooksPath is UNSET, the global hook was the entry point
#       and ALREADY called us; calling it back would loop infinitely.
#
# Composition rule (symmetric, runtime-detected):
#   Both hooks key off `git config core.hooksPath`:
#     - core.hooksPath SET   -> git invoked PROJECT directly; project delegates to global at the end.
#     - core.hooksPath UNSET -> git invoked GLOBAL directly; global delegates to project; project does NOT call back.
#   Each hook checks the same fact and decides whether it is the entry
#   point (delegates) or the callee (skips delegation). No sentinel
#   strings, no spelling-mismatch bugs.
#
# Lineage: pre-Wave-E hook chained scripts/check-docs-site.sh,
# scripts/check-mermaid-renders.sh, cargo fmt, cargo clippy, plus the
# parallel-migration runner block. P60 SIMPLIFY-10 collapsed that into
# the single runner invocation; the cred-hygiene scan stays IN the hook
# because the runner does not pipe stdin.
#
# Bypass (strongly discouraged -- rotate any leaked tokens AT THE
# ISSUING PLATFORM before bypassing):
#   git push --no-verify
#
# Install: bash scripts/install-hooks.sh

set -euo pipefail

readonly REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

# (1) Cred-hygiene gate (P0). Buffer stdin once -- the global hook in
# step (3) needs the same ref-range bytes git fed us, and stdin is
# single-shot.
stdin_buf=$(cat)
if [[ -n "$stdin_buf" ]]; then
  if ! printf '%s\n' "$stdin_buf" | bash "$REPO_ROOT/quality/gates/structure/cred-hygiene.sh"; then
    exit 1
  fi
fi

# (2) Quality Gates runner -- propagates exit code.
# Avoid `if ! cmd; then exit $?; fi` -- $? after `! cmd` is the exit of the
# negation (always 0), masking the real failure and letting bad pushes
# through (caught 2026-04-28 when push went through with FAIL rows).
python3 "$REPO_ROOT/quality/runners/run.py" --cadence pre-push
RUNNER_EXIT=$?
if [[ $RUNNER_EXIT -ne 0 ]]; then
  exit "$RUNNER_EXIT"
fi

# (3) Optional personal add-on chain. Only delegate to global when
# core.hooksPath is SET -- which proves git invoked us as the entry
# point and the global hook has NOT already run. When core.hooksPath is
# unset, the global was the entry point (it called us); calling it back
# would loop. The global hook applies the symmetric check: it delegates
# to the project hook only when core.hooksPath is UNSET.
GLOBAL="$HOME/.git-hooks/pre-push"
if [[ -n "$(git config core.hooksPath 2>/dev/null)" ]] && [[ -x "$GLOBAL" ]]; then
  printf '%s\n' "$stdin_buf" | "$GLOBAL" "$@"
fi
